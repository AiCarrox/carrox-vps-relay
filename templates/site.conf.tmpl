{{- /*
  vps-relay — managed site template.
  Variables (rendered by main.go):
    .Domain          : accelerated domain
    .Upstream        : full upstream URL (kept for relay-meta JSON)
    .UpstreamScheme  : http | https
    .UpstreamHost    : host part (domain or IPv4/IPv6)
    .UpstreamPort    : port (filled or defaulted from scheme)
    .UpstreamIsIP    : bool — true if UpstreamHost is an IP literal
    .Owner           : key_id of the owner (relay-meta)
    .CFZone          : zone name (relay-meta)
    .CFRecordID      : DNS record id (relay-meta)
    .CFRecordIDV6    : optional AAAA record id (relay-meta)
    .CreatedUTC      : ISO8601 timestamp (relay-meta)
*/ -}}
# ====== vps-relay managed: DO NOT HAND EDIT ======
# relay-meta: {"v":1,"domain":"{{.Domain}}","upstream":"{{.Upstream}}"{{if .Owner}},"owner":"{{.Owner}}"{{end}},"cf_zone":"{{.CFZone}}","cf_record_id":"{{.CFRecordID}}"{{if .CFRecordIDV6}},"cf_record_id_v6":"{{.CFRecordIDV6}}"{{end}},"created":"{{.CreatedUTC}}"}
# =================================================

server {
    listen 80;
    listen [::]:80;
    server_name {{.Domain}};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{.Domain}};

    ssl_certificate     /usr/local/nginx/conf/ssl/{{.Domain}}/fullchain.pem;
    ssl_certificate_key /usr/local/nginx/conf/ssl/{{.Domain}}/key.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    location / {
        proxy_pass {{.UpstreamScheme}}://{{.UpstreamHost}}:{{.UpstreamPort}};
        proxy_http_version 1.1;

        # Upstream Host: use upstream host name if it's a domain,
        # otherwise pass through the accelerated domain.
        proxy_set_header Host              {{if .UpstreamIsIP}}$host{{else}}{{.UpstreamHost}}{{end}};
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;

        # WebSocket / SSE passthrough
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        # Upstream SNI: use upstream host name if it's a domain,
        # otherwise fall back to the accelerated domain.
        proxy_ssl_server_name on;
        proxy_ssl_name        {{if .UpstreamIsIP}}$host{{else}}{{.UpstreamHost}}{{end}};
        proxy_ssl_verify      off;

        proxy_buffering       off;
        proxy_read_timeout    300s;
        proxy_send_timeout    300s;
        client_max_body_size  100m;
    }
}
